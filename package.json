{
  "name": "welcome-to-the-internet-qa",
  "version": "1.0.0",
  "scripts": {
    "cy:run": "cypress run",
    "cy:open": "cypress open",
    "report:merge": "mochawesome-merge cypress/results/*.json > cypress/results/output.json",
    "report:generate": "marge cypress/results/output.json -f report -o cypress/results",
    "report": "npm run report:merge && npm run report:generate"
  },
  "overrides": {
    "diff": "^8.0.3"
  },
  "devDependencies": {
    "cypress": "^15.11.0",
    "typescript": "^5.0.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2"
  }
}
